{
  "name": "norns-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "TheNorns — AI Program Management platform (monorepo)",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm run build && pnpm -r run typecheck",
    "test": "pnpm run build && pnpm -r run test",
    "test:e2e": "pnpm --filter @norns/web test:e2e",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "ci": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run test:e2e"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4"
  }
}
