+  background: var(--raised);
+  color: var(--muted);
+  border-radius: 11px;
+  padding: 0.65rem 0.5rem 0.65rem 0.85rem;
+  font-size: 0.78rem;
+  line-height: 1.4;
+  margin: 0.7rem 0;
+}
+.dismissible-note-close {
+  flex: none;
+  border: none;
+  background: transparent;
+  color: var(--muted);
+  font-size: 16px;
+  line-height: 1;
+  cursor: pointer;
+  padding: 2px 6px;
+}
+.dismissible-note-close:hover {
+  color: var(--text);
+}
