+  font-size: 11px;
+  white-space: pre-wrap;
+  word-break: break-word;
+}
+.run-log-meta {
+  display: flex;
+  justify-content: space-between;
+  gap: 10px;
+  font-size: 10.5px;
+  color: var(--muted);
+}
+.dismissible-note {
+  display: flex;
+  align-items: flex-start;
