+/* EXECUTION E13 — live cost + live run-log. */
+.cost-line {
+  display: flex;
+  align-items: baseline;
+  gap: 6px;
+  font-size: 11px;
+  color: var(--muted);
+}
+.cost-line .cost-amount {
+  color: var(--text);
+  font-weight: 600;
+}
+.cost-line .cost-unknown {
+  font-style: italic;
+}
+.run-log {
+  margin-top: 6px;
+  border: 1px solid var(--line);
+  border-radius: 9px;
+  background: var(--bg);
+}
+.run-log > summary {
+  cursor: pointer;
+  padding: 6px 10px;
+  font-size: 11px;
+  color: var(--muted);
+}
+.run-log-body {
+  border-top: 1px solid var(--line);
+  padding: 8px 10px;
+  display: grid;
+  gap: 6px;
+}
+.run-log-output {
+  margin: 0;
+  max-height: 220px;
+  overflow: auto;
+  padding: 8px;
+  border-radius: 7px;
