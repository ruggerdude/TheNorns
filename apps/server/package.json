{
  "name": "@norns/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "TheNorns backend: API, relay (browser + runner WebSockets), workflow engine, dispatch",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "migrate:phase2": "pnpm run build && node dist/phase2.js",
    "cutover:phase2-identity": "pnpm run build && node dist/phase2CutoverIdentity.js",
    "verify:phase2-restore": "pnpm run build && node dist/phase2VerifyRestore.js",
    "pilot:phase8": "pnpm run build && node dist/phase8Pilot.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/static": "^10.1.0",
    "@fastify/websocket": "^11.0.0",
    "@norns/adapters": "workspace:*",
    "@norns/contracts": "workspace:*",
    "@types/libsodium-wrappers": "^0.8.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "libsodium-wrappers": "^0.8.4",
    "pg": "^8.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@norns/runner": "workspace:*",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0",
    "ws": "^8.18.0"
  }
}
